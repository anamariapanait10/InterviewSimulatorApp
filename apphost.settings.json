{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Aspire.Hosting.Dcp": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },

  "AgentMode": "LlmHandOff",

  "LLM": {
    "Provider": "openai"
  },

  "GitHub": {
    "Token": "{{GITHUB_PAT}}",
    "Model": "openai/gpt-5-mini"
  },

  "OpenAI": {
    "ApiKey": "{{OPENAI_API_KEY}}",
    "Model": "gpt-4o-mini",
    "BaseUrl": "https://api.openai.com/v1"
  }

}